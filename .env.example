# Neon PostgreSQL — create a dev branch and a prod branch in the Neon console.
# Pooled URL for the app (recommended for Next.js serverless / many short-lived connections).
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Direct (non-pooled) URL for Prisma CLI: `migrate dev`, `migrate deploy`, `db execute`, etc.
# If omitted, Prisma CLI falls back to DATABASE_URL.
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Note: `prisma generate` / `next build` do not need a reachable DB. If both vars are unset,
# prisma.config.ts uses a placeholder URL for validation only—set real URLs before running migrations.

# After migrations, seed reference data (demo user, item types, collections, items):
# npm run db:seed
# Demo credentials (see `.cursor/features/seed-spec.md`): demo@devloot.io / 12345678
